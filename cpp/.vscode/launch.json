{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch SMTCLyrics",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/mingw-debug/SMTCLyrics.exe",
      "cwd": "${workspaceFolder}/build/mingw-debug",
      "MIMode": "gdb",
      "externalConsole": false,
      "preLaunchTask": "CMake: build debug"
    },
    {
      "name": "Run SMTCLyricsTests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/mingw-debug/SMTCLyricsTests.exe",
      "cwd": "${workspaceFolder}/build/mingw-debug",
      "MIMode": "gdb",
      "externalConsole": false,
      "preLaunchTask": "CMake: build debug"
    }
  ]
}
