{
  "version": 6,
  "configurePresets": [
    {
      "name": "mingw-debug",
      "displayName": "MinGW Debug",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/mingw-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "mingw-release",
      "displayName": "MinGW Release",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/mingw-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "mingw-size",
      "displayName": "MinGW Size Optimized",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/mingw-size",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel",
        "SMTCLYRICS_ENABLE_LTO": "OFF",
        "SMTCLYRICS_STRIP_RELEASE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug"
    },
    {
      "name": "mingw-release",
      "configurePreset": "mingw-release"
    },
    {
      "name": "mingw-size",
      "configurePreset": "mingw-size"
    }
  ]
}
